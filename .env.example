# OpenAI
OPENAI_API_KEY=

# Chatwoot — non-secret IDs (real values in CLAUDE.md)
CHATWOOT_BASE_URL=https://chat.fomo.com.ar
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=3
CHATWOOT_AGENT_BOT_ID=2
CHATWOOT_TEAM_ID=1

# Chatwoot — secrets (DO NOT commit; copy real values into .env only)
CHATWOOT_PATH_TOKEN=
# CHATWOOT_API_TOKEN can be left empty in dev/Studio — outbound replies will
# be skipped with a warning. Required for production (handoff + reply post).
CHATWOOT_API_TOKEN=

# FOMO
CALENDLY_LINK=

# Mastra Memory storage (LibSQL). Local dev keeps it at the repo root.
# In Docker we override this to live inside a mounted volume.
MASTRA_DB_URL=file:./mastra.db

# Twenty CRM (v2). Vacío en dev/Studio — el upsert se skipea con warning si falta TWENTY_API_KEY.
# Requerido en producción para que los leads se registren.
TWENTY_API_URL=
TWENTY_API_KEY=
TWENTY_OWNER_USER_ID=

# Runtime
NODE_ENV=development
LOG_LEVEL=info
PORT=4111
